{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "fhir2": "^1.2.0",
    "webservices.rest": "^2.24.0"
  },
  "extensions": [
    {
      "name": "fila-link",
      "slot": "patient-chart-dashboard-slot",
      "component": "filaDashboardLink",
      "meta": {
        "slot": "patient-chart-fila-dashboard-slot",
        "columns": 1,
        "path": "fila"
      }
    },
    {
      "name": "fila-form",
      "slot": "patient-chart-fila-dashboard-slot",
      "component": "root",
      "order": 1,
      "meta": {
        "title": "FILA",
        "view": "fila"
      }
    },
    {
      "name": "Red box",
      "component": "redBox",
      "slot": "Boxes"
    },
    {
      "name": "Blue box",
      "component": "blueBox",
      "slot": "Boxes"
    },
        {
      "name": "Brand box",
      "component": "blueBox",
      "slot": "Boxes"
    }
  ],
  "pages": [
    {
      "component": "root",
      "route": "fila"
    }
  ]
}
